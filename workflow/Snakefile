import os
import pandas as pd
configfile: "config.yaml"

# Repository root (workflow/ is inside repo root)
ROOT = os.path.abspath(os.path.join(os.path.dirname(__file__), '..'))

# Define the input file containing the necessary information
input_file = os.path.join(ROOT, "data", "dataset", "20130502.phase3.exome.sequence.index")  # Replace with your actual input file path

# Load the relevant data from the input file
data = pd.read_csv(input_file, sep="\t")  # Adjust the separator if needed

# Filter rows where the first column contains "_1.filt.fastq.gz"
filtered_data = data[data.iloc[:, 0].str.contains("_1.filt.fastq.gz")]

# Create a list of tuples (sample_name, url_1, url_2)
downloads = [(row[2], row[0].replace("_1.filt.fastq.gz", "_1.filt.fastq.gz"), 
               row[0].replace("_1.filt.fastq.gz", "_2.filt.fastq.gz")) for idx, row in filtered_data.iterrows()]


# Define rules for downloading and renaming files

SAMPLES = [name for name, _, _ in downloads]

# Rule to define the final output
rule all:
    input:
        expand(os.path.join(ROOT, "data", "bam", "{sample_name}.recal.bam"), sample_name=SAMPLES)  # Add your sample names here


rule download_fastq:
    input:
        url_1=lambda wildcards: next(url for name, url_1, url_2 in downloads if name == wildcards.sample),
        url_2=lambda wildcards: next(url for name, url_1, url_2 in downloads if name == wildcards.sample)
    output:
        os.path.join(ROOT, "data", "fq", "{sample}_val_1.fastq.gz"),
        os.path.join(ROOT, "data", "fq", "{sample}_val_2.fastq.gz")
    shell:
        """
        wget {input.url_1} -O {output[0]} && 
        wget {input.url_2} -O {output[1]}
        """

# Note: Ensure that you have 'wget' installed or replace it with another download method if necessary.

# Rule to align reads using BWA
rule bwa_align:
    input:
        ref=config['reference'],
        r1=os.path.join(ROOT, "data", "fq", "{sample_name}_val_1.fq.gz"),
        r2=os.path.join(ROOT, "data", "fq", "{sample_name}_val_2.fq.gz")
    output:
        os.path.join(ROOT, "data", "bam", "{sample_name}.bam")
    params:
        rg="@RG\\tID:{sample_name}\\tSM:{sample_name}\\tLB:{sample_name}\\tPL:ILLUMINA",
        threads=12
    shell:
        "bwa mem -a -M -t {params.threads} -O 5 -E 3 -R {params.rg} {input.ref} {input.r1} {input.r2} | "
        "samtools view -b -o {output}"

# Rule to sort BAM files
rule sort_bam:
    input:
        os.path.join(ROOT, "data", "bam", "{sample_name}.bam")
    output:
        os.path.join(ROOT, "data", "bam", "{sample_name}.sort.bam")
    params:
        threads=8
    shell:
        "samtools sort -@ {params.threads} -o {output} {input}"

# Rule to mark duplicates using Picard
rule mark_duplicates:
    input:
        bam=os.path.join(ROOT, "data", "bam", "{sample_name}.sort.bam")
    output:
        dedup_bam=os.path.join(ROOT, "data", "bam", "{sample_name}.dedup.bam"),
        metrics=os.path.join(ROOT, "data", "bam", "{sample_name}.dedup.metrics")
    params:
        picard_jar="picard.jar",
        memory="24g"
    shell:
        "java -Xmx{params.memory} -jar {params.picard_jar} MarkDuplicates "
        "INPUT={input.bam} OUTPUT={output.dedup_bam} METRICS_FILE={output.metrics} && "
        "samtools index {output.dedup_bam}"

# Rule for base recalibration
rule base_recalibrate:
    input:
        bam=os.path.join(ROOT, "data", "bam", "{sample_name}.dedup.bam"),
        ref=config['reference']
    output:
        os.path.join(ROOT, "data", "bam", "{sample_name}.recal_data.grp")
    params:
        memory="24g"
    shell:
        "gatk --java-options '-Xmx{params.memory}' BaseRecalibrator "
        "-R {input.ref} -I {input.bam} "
        f"--known-sites {os.path.join(ROOT, 'data', 'ref', 'Mills_and_1000G_gold_standard_indels.vcf')} "
        f"--known-sites {os.path.join(ROOT, 'data', 'ref', 'KG_phase1_snp.vcf')} "
        f"--known-sites {os.path.join(ROOT, 'data', 'ref', 'dbsnp138.vcf')} "
        "-O {output}"

# Rule to apply base quality score recalibration
rule apply_bqsr:
    input:
        bam=os.path.join(ROOT, "data", "bam", "{sample_name}.dedup.bam"),
        recal_data=os.path.join(ROOT, "data", "bam", "{sample_name}.recal_data.grp"),
        ref=config['reference']
    output:
        os.path.join(ROOT, "data", "bam", "{sample_name}.recal.bam")
    params:
        memory="24g"
    shell:
        "gatk --java-options '-Xmx{params.memory}' ApplyBQSR "
        "-R {input.ref} -I {input.bam} -bqsr {input.recal_data} "
        "-O {output}"

# Rule to index the final recalibrated BAM file
rule index_recal_bam:
    input:
        os.path.join(ROOT, "data", "bam", "{sample_name}.recal.bam")
    output:
        os.path.join(ROOT, "data", "bam", "{sample_name}.recal.bai")
    shell:
        "samtools index {input}"

# CNV Calling Workflow
rule collect_read_counts:
    input:
        plan="../plans/{sample}.plan.yaml"
    output:
        readcounts="{sample}.readcounts.tsv"
    run:
        import yaml, subprocess, os
        plan = yaml.safe_load(open(input.plan))
        bam = plan['bam']
        interval = plan['interval']
        reference = plan['reference']
        gatk = plan.get('gatk', 'gatk')
        out = output.readcounts
        cmd = [gatk, 'CollectReadCounts', '-L', interval, '-R', reference, '-imr', 'OVERLAPPING_ONLY', '-I', bam, '--format', 'TSV', '-O', out]
        print('Running:', ' '.join(cmd))
        subprocess.check_call(cmd)

rule determine_germline_contig_ploidy:
    input:
        plan="../plans/{sample}.plan.yaml",
        readcounts="{sample}.readcounts.tsv"
    output:
        ploidy_calls="ploidy-case-calls"
    run:
        import yaml, subprocess
        plan = yaml.safe_load(open(input.plan))
        model = plan.get('ploidy_model', 'model/ploidy-model')
        gatk = plan.get('gatk', 'gatk')
        out = output.ploidy_calls
        cmd = [gatk, 'DetermineGermlineContigPloidy', '--model', model, '-I', input.readcounts, '-O', out, '--output-prefix', 'ploidy-case', '--verbosity', 'DEBUG']
        print('Running:', ' '.join(cmd))
        subprocess.check_call(cmd)

rule call_germline_cnvs:
    input:
        plan="../plans/{sample}.plan.yaml",
        readcounts="{sample}.readcounts.tsv",
        ploidy_calls="ploidy-case-calls"
    output:
        cnv_calls="{sample}-calls"
    run:
        import yaml, subprocess
        plan = yaml.safe_load(open(input.plan))
        model = plan.get('model', 'model/baseline-model')
        gatk = plan.get('gatk', 'gatk')
        outdir = output.cnv_calls
        sample_name = snakemake.wildcards.sample
        cmd = [gatk, 'GermlineCNVCaller', '--run-mode', 'CASE', '-I', input.readcounts, '--contig-ploidy-calls', input.ploidy_calls, '--model', model, '--output', outdir, '--output-prefix', sample_name, '--verbosity', 'DEBUG']
        print('Running:', ' '.join(cmd))
        subprocess.check_call(cmd)

rule postprocess_germline_cnv_calls:
    input:
        plan="../plans/{sample}.plan.yaml",
        cnv_calls="{sample}-calls",
        ploidy_calls="ploidy-case-calls"
    output:
        genotyped_intervals="{sample}.genotyped-intervals.vcf.gz",
        genotyped_segments="{sample}.genotyped-segments.vcf.gz",
        denoised_copy_ratios="{sample}.denoised-copy-ratios.txt"
    run:
        import yaml, subprocess
        plan = yaml.safe_load(open(input.plan))
        model = plan.get('model', 'model/baseline-model')
        reference_dict = plan.get('reference_dict', os.path.join(ROOT, 'data', 'hg19_chr20.dict'))
        gatk = plan.get('gatk', 'gatk')
        cmd = [gatk, 'PostprocessGermlineCNVCalls', '--model-shard-path', model, '--calls-shard-path', input.cnv_calls, '--allosomal-contig', 'chrX', '--allosomal-contig', 'chrY', '--contig-ploidy-calls', input.ploidy_calls, '--sample-index', '0', '--output-genotyped-intervals', output.genotyped_intervals, '--output-genotyped-segments', output.genotyped_segments, '--output-denoised-copy-ratios', output.denoised_copy_ratios, '--sequence-dictionary', reference_dict]
        print('Running:', ' '.join(cmd))
        subprocess.check_call(cmd)

# Plan agent: generate per-sample YAML plans for CNV analysis
rule run_plan_agent:
    input:
        bam=os.path.join(ROOT, "data", "bam", "{sample}.recal.bam")
    output:
        plan="../plans/{sample}.plan.yaml"
    params:
        script="../scripts/plan_agent.py"
    shell:
        """
        python {params.script} --sample {wildcards.sample} --bam {input.bam} --out {output.plan}
        """

rule annotate_intervals:
    input:
        interval=os.path.join(ROOT, 'data', 'targets.preprocessed.500.interval_list')
    output:
        os.path.join(ROOT, 'data', 'targets.preprocessed.500.annotated_intervals.tsv')
    run:
        gatk = config.get('gatk', 'gatk')
        cmd = [gatk, 'AnnotateIntervals', '--intervals', input.interval, '--reference', config.get('reference'), '--interval-merging-rule', 'OVERLAPPING_ONLY', '--output', output[0]]
        try:
            print('Running:', ' '.join(cmd))
            subprocess.check_call(cmd)
        except Exception:
            with open(output[0], 'w') as fh:
                fh.write('# annotated_intervals\nCONTIG\tSTART\tEND\tGC\nchr20\t10000\t20000\t0.42\n')



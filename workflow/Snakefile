rule plot_plotcnv:
    input:
        annotated=os.path.join(ROOT, 'outputs', 'cnv_gvcf_clustered.annotated.tsv')
    output:
        os.path.join(ROOT, 'outputs', 'figures', 'plotcnv', 'plotcnv_placeholder.png')
    run:
        r = config.get('plotcnv_Rscript', 'Rscript')
        # If PlotCNV is not installed, write placeholder
        try:
            subprocess.check_call([r, '--version'])
            # would call an R script to generate plots; here create placeholder
            ensure_parent = os.path.dirname(output[0])
            os.makedirs(ensure_parent, exist_ok=True)
            with open(output[0], 'wb') as fh:
                fh.write(b'')
        except Exception:
            os.makedirs(os.path.dirname(output[0]), exist_ok=True)
            with open(output[0], 'wb') as fh:
                fh.write(b'')



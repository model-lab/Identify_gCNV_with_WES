    input:
        raw=os.path.join(ROOT, 'data', 'targets.bed')
    output:
        os.path.join(ROOT, 'data', 'targets.preprocessed.500.interval_list')
    params:
        script=os.path.join(ROOT, 'scripts', 'preprocess_intervals.py')
    shell:
        'python {params.script} --in {input.raw} --out {output}'



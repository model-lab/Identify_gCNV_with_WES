import os

# Resolve repository root (two levels up from this Snakefile: workflow/smoke -> repo root)
ROOT = os.path.abspath(os.path.join(os.path.dirname(__file__), '..', '..'))

rule all:
    input:
        os.path.join(ROOT, "plans", "EXAMPLE.plan.yaml"),
        os.path.join(ROOT, "outputs", "EXAMPLE.genotyped-intervals.vcf.gz"),
        os.path.join(ROOT, "outputs", "EXAMPLE.genotyped-segments.vcf.gz")

rule create_fake_bam:
    output:
        os.path.join(ROOT, "data", "bam", "EXAMPLE.recal.bam")
    shell:
        """
        mkdir -p ../data/bam
        touch {output}
        """

rule run_plan_agent:
    input:
        bam=os.path.join(ROOT, "data", "bam", "EXAMPLE.recal.bam")
    output:
        plan=os.path.join(ROOT, "plans", "EXAMPLE.plan.yaml")
    params:
        script=os.path.join(ROOT, "scripts", "plan_agent.py")
    shell:
        "python {params.script} --sample EXAMPLE --bam {input.bam} --out {output.plan}"

rule fake_postprocess:
    input:
        plan=os.path.join(ROOT, "plans", "EXAMPLE.plan.yaml")
    output:
        intervals=os.path.join(ROOT, "outputs", "EXAMPLE.genotyped-intervals.vcf.gz"),
        segments=os.path.join(ROOT, "outputs", "EXAMPLE.genotyped-segments.vcf.gz")
    shell:
        """
        mkdir -p ../outputs
        echo "##FAKE VCF" > {output.intervals}
        echo "##FAKE SEGMENTS" > {output.segments}
        """

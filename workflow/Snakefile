import os
import glob
import subprocess

configfile: "config.yaml"

# Repository root
ROOT = os.path.abspath(os.path.join(os.path.dirname(__file__), '..'))

# Discover samples via plans/ or data/bam
PLAN_DIR = os.path.join(ROOT, 'plans')
plan_files = sorted(glob.glob(os.path.join(PLAN_DIR, '*.plan.yaml')))

def _plan_sample_name(path):
    base = os.path.basename(path)
    if base.endswith('.plan.yaml'):
        return base[:-len('.plan.yaml')]
    return os.path.splitext(base)[0]

if plan_files:
    SAMPLES = [_plan_sample_name(p) for p in plan_files]
else:
    bam_files = sorted(glob.glob(os.path.join(ROOT, 'data', 'bam', '*.bam')))
    SAMPLES = [os.path.splitext(os.path.basename(b))[0] for b in bam_files]

if not SAMPLES:
    # No samples found; keep SAMPLES empty but warn so users can correct inputs
    print('Warning: no samples discovered in plans/ or data/bam; SAMPLES is empty')


rule all:
    input:
        expand(os.path.join(ROOT, 'outputs', '{sample}.genotyped-intervals.vcf.gz'), sample=SAMPLES),
        os.path.join(ROOT, 'outputs', 'cnv_gvcf_clustered.annotated.tsv'),
        os.path.join(ROOT, 'outputs', 'figures', 'knot', 'knot_placeholder.html'),
        os.path.join(ROOT, 'outputs', 'figures', 'vcf2circos', 'vcf2circos_placeholder.png')


